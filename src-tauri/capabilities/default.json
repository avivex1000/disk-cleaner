{
  "identifier": "default",
  "description": "Default capabilities for Disk Cleaner",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "core:window:allow-maximize",
